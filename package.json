{
  "name": "buy-one-shoe",
  "version": "1.0.0",
  "description": "Co-buying marketplace for items sold in pairs/sets",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node --experimental-sqlite server.js",
    "dev:server": "node --experimental-sqlite server.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install && cd .. && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
